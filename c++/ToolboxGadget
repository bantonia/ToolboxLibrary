ToolboxGadget& ToolboxGadget::fade() {
  this->setGadgetFlags(this->getGadgetFlags() | (1 << 31));
  return *this;
}

ToolboxGadget& ToolboxGadget::unfade() {
  this->setGadgetFlags(this->getGadgetFlags() & ~(1 << 31));
  return *this;
}
