#include "ToolboxGadget.h"

ToolboxGadget& ToolboxGadget::gadgetMethod(int methodCode, _kernel_swi_regs *regs) {
  _kernel_oserror *err = 0;
  regs->r[0] = flags;
  regs->r[1] = windowId;
  regs->r[2] = methodCode;
  regs->r[3] = gadgetId;
  err = _kernel_swi(Toolbox_ObjectMiscOp, regs, regs);
  if (err != 0 ) {
    ToolboxGadget::setLastError(err, __LINE__ -2);
  }
  return *this;
}

ToolboxGadget::ToolboxGadget() : windowId(0), gadgetId(0), flags(0) {}

ToolboxGadget::ToolboxGadget(ObjectId windowId, ComponentId gadgetId) : flags(0) {
 this->windowId = windowId;
 this->gadgetId = gadgetId;
 flags = getGadgetFlags();
}

ToolboxGadget::ToolboxGadget(ObjectId windowId, ComponentId gadgetId, unsigned int flags) {
  this->windowId = windowId;
  this->gadgetId = gadgetId;
  this->flags = flags;
  setGadgetFlags(flags);
}

int ToolboxGadget::getGadgetFlags() {
  _kernel_swi_regs regs;
  this->gadgetMethod(Gadget_GetFlags, &regs);
  flags = regs.r[0];
  return regs.r[0];
}

ToolboxGadget& ToolboxGadget::setGadgetFlags(unsigned int flags) {
  _kernel_swi_regs regs;
  //this->flags = 0;
  regs.r[4] = (int) flags;
  this->gadgetMethod(Gadget_SetFlags, &regs);
  flags = flags;
  return *this;
}

