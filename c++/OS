char *OS::binaryToDecimal(int n, char *buffer, int *bufSize) {
  _kernel_oserror *err = 0;
   _kernel_swi_regs in, out;
  in.r[0] = n;
  in.r[1] = (int) buffer;
  in.r[2] = *bufSize;
  err = _kernel_swi(OS_BinaryToDecimal, &in, &out);
  if (err != 0) {
    ErrorReport::setLastError(err, __LINE__ -2);
  }
  *bufSize = out.r[2];
  buffer[*bufSize] = 0;
  return buffer;
}

