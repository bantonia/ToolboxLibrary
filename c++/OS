char *OS::convertHex(int n, char *buffer, int *bufSize) {
  _kernel_oserror *err = 0;
  _kernel_swi_regs in, out;
  in.r[0] = n;
  in.r[1] = (int) buffer;
  in.r[2] = *bufSize;
  if ((n >> 4) == 0) {
    err = _kernel_swi(OS_ConvertHex1, &in, &out);
    if (err != 0) {
      ErrorReport::setLastError(err, __LINE__ -2);
    }
  } else {
    if ((n >> 8) == 0) {
      err = _kernel_swi(OS_ConvertHex2, &in, &out);
      if (err != 0) {
        ErrorReport::setLastError(err, __LINE__ -2);
      }
    } else {
      if ((n >> 16) == 0) {
        err = _kernel_swi(OS_ConvertHex4, &in, &out);
        if (err != 0) {
          ErrorReport::setLastError(err, __LINE__ -2);
        }
      } else {
        if ((n >> 24) == 0) {
          err = _kernel_swi(OS_ConvertHex6, &in, &out);
          if (err != 0) {
            ErrorReport::setLastError(err, __LINE__ -2);
          }
        } else {
          err = _kernel_swi(OS_ConvertHex8, &in, &out);
          if (err != 0) {
            ErrorReport::setLastError(err, __LINE__ -2);
          }
        }
      }
    }
  }
  *bufSize = out.r[2];
  buffer[*bufSize] = 0;
  return buffer;
}

