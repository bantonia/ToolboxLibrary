unsigned int OS::readMonotonicTime() {
  _kernel_swi_regs in, out;
  _kernel_oserror *err = _kernel_swi(OS_ReadMonotonicTime, &in, &out);
  if (err != 0) {
    ErrorReport::setLastError(err, __LINE__ -2);
  }
  return out.r[0];
}

