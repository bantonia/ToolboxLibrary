unsigned WimpWindowObj::updateWindow(int minX, int minY, int maxX, int maxY) {
  _kernel_oserror *err = 0;
  _kernel_swi_regs in, out;
  unsigned *block = WimpObj::getPollBlock();
  block[0] = (unsigned) handle;
  block[1] = minX;
  block[2] = minY;
  block[3] = maxX;
  block[4] = maxY;
  in.r[1] = (int) block;
  err = _kernel_swi(Wimp_UpdateWindow, &in, &out);
  if (err != 0) {
    WimpObj::setLastError(err, __LINE__ -2);
  }
  return out.r[0];
}

