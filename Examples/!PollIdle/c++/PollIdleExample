#include "PollIdleExample.h"

PollIdleExample::PollIdleExample() : ToolboxTask(),
  res_Iconbar(NULL),
  res_Window(NULL),
  res_Menu(NULL) {}

PollIdleExample::~PollIdleExample() {
  if (res_Window != NULL) delete res_Window;
  if (res_Menu != NULL) delete res_Menu;
  if (res_Iconbar != NULL) delete res_Iconbar;
}

void PollIdleExample::toolboxObjectAutoCreated(int objectClass) {
  switch(objectClass) {
    case ToolboxEvents::IconbarObjectClass: {
        iconbarObjectAutoCreated();
      }
      break;
    case ToolboxEvents::WindowObjectClass: {
        windowObjectAutoCreated();
      }
      break;
    case ToolboxEvents::MenuObjectClass: {
        menuObjectAutoCreated();
      }
      break;
    default:
      break;
  }
}

void PollIdleExample::windowObjectAutoCreated() {
  ToolboxObjectAutoCreatedEvent *pollEvent = (ToolboxObjectAutoCreatedEvent *) getPollBlock();
  IdBlock *idBlock = &ToolboxCoreObj::idBlock;
  if (strcmp(pollEvent->template_name, "Window") == 0) {
    res_Window = new Res_Window(idBlock);
  }
}

void PollIdleExample::menuObjectAutoCreated() {
  ToolboxObjectAutoCreatedEvent *pollEvent = (ToolboxObjectAutoCreatedEvent *) getPollBlock();
  IdBlock *idBlock = &ToolboxCoreObj::idBlock;
  if (strcmp(pollEvent->template_name, "Menu") == 0) {
    res_Menu = new Res_Menu(idBlock);
  }
}

void PollIdleExample::iconbarObjectAutoCreated() {
  ToolboxObjectAutoCreatedEvent *pollEvent = (ToolboxObjectAutoCreatedEvent *) getPollBlock();
  IdBlock *idBlock = &ToolboxCoreObj::idBlock;
  if (strcmp(pollEvent->template_name, "Iconbar") == 0) {
    res_Iconbar = new Res_Iconbar(idBlock);
  }
}

void PollIdleExample::toolboxEventHandler(int event) {
  switch(event) {
    case ToolboxEvents::QuitQuit: {
        quitQuit();
      }
      break;
    default:
      break;
  }
}

void PollIdleExample::toolboxUserEvent(int event) {
  IdBlock *idBlock = &ToolboxCoreObj::idBlock;
  switch(event) {
    case 2:
    case 3: {
        res_Window->updateDisplay(event);
      }
      break;
    default:
      break;
  }
}

void PollIdleExample::quitQuit() {
  quit = 1;
}

void PollIdleExample::nullReason() {
  Event::eventDispatcher();
}
